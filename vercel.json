{
  "version": 2,
  "builds": [
    {
      "src": "rex-os/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/rex-os/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/rex-os/$1"
    }
  ]
}
