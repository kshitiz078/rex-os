{
  "buildCommand": "cd backend && npm install && npx prisma generate && cd ../rex-os && npm install && npm run build",
  "outputDirectory": "rex-os/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
