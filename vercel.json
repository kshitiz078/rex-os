{
  "buildCommand": "npx prisma generate --schema=backend/prisma/schema.prisma && cd rex-os && npm run build",
  "outputDirectory": "rex-os/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
